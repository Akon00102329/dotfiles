#
# application hotkeys
#

# terminal emulator
super + Return
	alacritty

# program launcher
Menu
	dmenu_run

# browser
super + b
  qutebrowser

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# switch between desktops
super + {_,shift + }{1-3}
  bspc {desktop -f, node -d} '^{1-3}'

# move between monitors
super + {_,shift + }{h,l}
 bspc node -{f,s} {west,east}
